# 数据库配置 (MySQL)
# 格式: mysql+aiomysql://用户名:URL编码密码@主机:端口/数据库名
# 注意: 密码中的特殊字符需要 URL 编码，如 @ -> %40, # -> %23 等
DATABASE_URL=mysql+aiomysql://root:password@127.0.0.1:3306/ev_check

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# JWT 配置
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 日志级别
LOG_LEVEL=INFO
